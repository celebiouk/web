# Cele.bio Environment Variables
# Copy this file to .env.local and fill in your values

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe (Phase 3 - just placeholders for now)
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# PayPal Connect
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_REDIRECT_URI=http://localhost:3000/api/paypal/connect/callback
PAYPAL_MODE=sandbox

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Cele.bio
ADMIN_EMAILS=profmendel@gmail.com,cc@cele.bio

# Resend
RESEND_API_KEY=re_xxx

# CreatorLab OAuth Provider
CREATORLAB_CLIENT_ID=your_creatorlab_client_id
CREATORLAB_CLIENT_SECRET=your_creatorlab_client_secret
CREATORLAB_REDIRECT_URI=https://creatorlab.example.com/auth/integrations/celebio/callback
# For multiple URIs use comma-separated: CREATORLAB_REDIRECT_URIS=http://localhost:3000/...,https://app.creatorlab.com/...

# CreatorLab import webhooks
CREATORLAB_IMPORT_WEBHOOK_URL=https://creatorlab.example.com/webhooks/cele-bio
CREATORLAB_WEBHOOK_SECRET=your_creatorlab_webhook_secret

# TikTok Login Kit (configure provider in Supabase dashboard)
TIKTOK_CLIENT_ID=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
