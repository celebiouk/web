# Cele.bio Environment Variables
# Copy this file to .env.local and fill in your values

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe (Phase 3 - just placeholders for now)
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# PayPal Connect
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_REDIRECT_URI=http://localhost:3000/api/paypal/connect/callback
PAYPAL_MODE=sandbox

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Cele.bio
ADMIN_EMAILS=profmendel@gmail.com,cc@cele.bio

# Resend
RESEND_API_KEY=re_xxx

# TikTok Login Kit (configure provider in Supabase dashboard)
TIKTOK_CLIENT_ID=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
TIKTOK_REDIRECT_URI=https://www.cele.bio/api/auth/callback/tiktok
TIKTOK_OAUTH_SCOPE=user.info.basic

# Instagram / Meta Automation (comment triggers + DMs)
# Get these from https://developers.facebook.com → Your App → Settings → Basic
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
# Any random string you choose — paste the same value into the Meta webhook config
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=your_random_verify_token

# TikTok Comment Automation (uses same app as TikTok login but needs extra scopes)
# Add this redirect URI to your TikTok developer app alongside the login one
TIKTOK_AUTOMATION_REDIRECT_URI=https://cele.bio/api/tiktok/automation/auth/callback

# Cron job authentication (set this in Vercel too — any random secret string)
CRON_SECRET=your_random_cron_secret

# CeleStudio (AI ebook builder) — get key from https://platform.openai.com/api-keys
# "standard" tier uses gpt-4.1-mini, "premium" reserved for gpt-4.1 (advanced polish)
OPENAI_API_KEY=sk-proj-xxx

# Content Scheduler — LinkedIn (first platform live; Pro feature in dashboard).
# Create an app at https://www.linkedin.com/developers/apps → request the
# "Sign In with LinkedIn using OpenID Connect" + "Share on LinkedIn" products.
# Add redirect URL: https://cele.bio/api/social/callback/linkedin
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# Optional override — defaults to {origin}/api/social/callback/linkedin if blank.
LINKEDIN_REDIRECT_URI=

# Content Scheduler — YouTube (Google OAuth 2.0).
# Create credentials at https://console.cloud.google.com → APIs & Services →
# Credentials → Create OAuth 2.0 Client ID (Web application type).
# Enable the "YouTube Data API v3" in Library first.
# Add redirect URI: https://www.cele.bio/api/social/callback/youtube
# Shared with CeleStudio — GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET may
# already exist if OpenAI is the AI provider; otherwise create fresh ones.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional override — defaults to {origin}/api/social/callback/youtube if blank.
YOUTUBE_REDIRECT_URI=

# Unsplash topical photo search for cover + chapter hero images.
# Get an Access Key from https://unsplash.com/developers (free, demo tier
# allows 50 req/hr — request production approval for 5000/hr).
# If unset, CeleStudio falls back to random Lorem Picsum photos (still works
# but covers won't be topical).
UNSPLASH_ACCESS_KEY=your_unsplash_access_key
